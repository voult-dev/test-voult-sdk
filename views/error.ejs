<% layout('layout/boilerplate.ejs') %>
<%
  var code = typeof err.statusCode !== 'undefined' ? err.statusCode : (typeof err.status !== 'undefined' ? err.status : 500);
  var is404 = code === 404;
  var isClient = code >= 400 && code < 500;
%>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">
      <div class="card border-0 shadow-sm overflow-hidden">
        <div class="row g-0 align-items-stretch">
          <div class="col-md-4 d-flex align-items-center justify-content-center p-4 p-md-0 <%= is404 ? 'bg-primary bg-opacity-10' : (isClient ? 'bg-warning bg-opacity-10' : 'bg-danger bg-opacity-10') %>">
            <div class="text-center py-md-5">
              <% if (is404) { %>
                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-white shadow-sm text-primary mb-2 mb-md-0" style="width: 5.5rem; height: 5.5rem;">
                  <i class="fa-solid fa-magnifying-glass fa-2x"></i>
                </span>
              <% } else if (isClient) { %>
                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-white shadow-sm text-warning mb-2 mb-md-0" style="width: 5.5rem; height: 5.5rem;">
                  <i class="fa-solid fa-hand fa-2x"></i>
                </span>
              <% } else { %>
                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-white shadow-sm text-danger mb-2 mb-md-0" style="width: 5.5rem; height: 5.5rem;">
                  <i class="fa-solid fa-bolt fa-2x"></i>
                </span>
              <% } %>
              <div class="mt-3 d-md-none">
                <span class="display-6 fw-bold <%= is404 ? 'text-primary' : (isClient ? 'text-warning-emphasis' : 'text-danger') %>"><%= code %></span>
              </div>
            </div>
          </div>
          <div class="col-md-8">
            <div class="card-body p-4 p-md-5">
              <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
                <div>
                  <p class="text-uppercase small text-secondary fw-semibold mb-1" style="letter-spacing: 0.06em;">Error</p>
                  <h1 class="h3 fw-bold mb-0" style="font-family: 'Plus Jakarta Sans', sans-serif;">
                    <% if (is404) { %>
                      Page not found
                    <% } else if (code === 403) { %>
                      Access denied
                    <% } else if (isClient) { %>
                      Request could not be completed
                    <% } else { %>
                      Something went wrong
                    <% } %>
                  </h1>
                </div>
                <span class="d-none d-md-inline-flex align-items-center justify-content-center rounded-3 fw-bold <%= is404 ? 'bg-primary text-white' : (isClient ? 'bg-warning text-dark' : 'bg-danger text-white') %> px-3 py-2" style="min-width: 3.25rem;"><%= code %></span>
              </div>
              <p class="text-secondary mb-4"><%= err.message || 'An unexpected error occurred.' %></p>
              <div class="d-flex flex-wrap gap-2">
                <a href="/" class="btn btn-primary">
                  <i class="fa-solid fa-house me-2"></i>Home
                </a>
                <a href="/voult" class="btn btn-outline-secondary">
                  <i class="fa-solid fa-flask me-2"></i>Playground
                </a>
                <% if (typeof req !== 'undefined' && req.get && req.get('referer')) { %>
                  <a href="<%= req.get('referer') %>" class="btn btn-outline-dark">
                    <i class="fa-solid fa-arrow-left me-2"></i>Back
                  </a>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
