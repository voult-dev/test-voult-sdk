<% layout('layout/boilerplate.ejs') %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <h1 class="h3 mb-3">Sign in — username</h1>
      <form action="/signin/username" method="POST" class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="mb-3">
            <label class="form-label" for="username">Username</label>
            <input class="form-control" id="username" name="username" type="text" autocomplete="username" required>
          </div>
          <div class="mb-3">
            <label class="form-label" for="password">Password</label>
            <input class="form-control" id="password" name="password" type="password" autocomplete="current-password" required>
          </div>
          <%- include('../partials/voult-form-footer') %>
          <button type="submit" class="btn btn-dark mt-2">signInWithUsernameAndPassword</button>
        </div>
      </form>
      <p class="mt-3"><a href="/voult">← Playground</a></p>
    </div>
  </div>
</div>
