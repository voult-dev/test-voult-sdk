<% layout('layout/boilerplate.ejs') %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <h1 class="h3 mb-3">Sign up — username</h1>
      <p class="text-secondary small"><%= passwordHint %></p>
      <form action="/voult/signup/username" method="POST" class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="mb-3">
            <label class="form-label" for="username">Username</label>
            <input class="form-control" id="username" name="username" type="text" autocomplete="username" required>
          </div>
          <div class="mb-3">
            <label class="form-label" for="password">Password</label>
            <input class="form-control" id="password" name="password" type="password" autocomplete="new-password" required>
          </div>
          <div class="mb-3">
            <label class="form-label" for="fullName">Full name <span class="text-muted">(optional)</span></label>
            <input class="form-control" id="fullName" name="fullName" type="text" autocomplete="name">
          </div>
          <div class="mb-3">
            <label class="form-label" for="email">Email <span class="text-muted">(optional)</span></label>
            <input class="form-control" id="email" name="email" type="email" autocomplete="email">
          </div>
          <%- include('../partials/voult-form-footer') %>
          <button type="submit" class="btn btn-primary mt-2">signUpWithUsernameAndPassword</button>
        </div>
      </form>
      <p class="mt-3"><a href="/voult">← Playground</a></p>
    </div>
  </div>
</div>
