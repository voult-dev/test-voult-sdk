<% layout('layout/boilerplate.ejs') %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <h1 class="h3 mb-3">Magic link sign-in</h1>
      <p class="text-secondary small">
        Uses <code>signInWithEmailLink</code>. Default redirect is this app’s callback:
        <span class="code-inline d-block mt-1"><%= suggestedRedirectUri %></span>
      </p>
      <form action="/signin/magicLink" method="POST" class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="mb-3">
            <label class="form-label" for="email">Email</label>
            <input class="form-control" id="email" name="email" type="email" autocomplete="email" required>
          </div>
          <div class="mb-3">
            <label class="form-label" for="redirectUri">redirectUri <span class="text-muted">(optional)</span></label>
            <input class="form-control font-monospace small" id="redirectUri" name="redirectUri" type="url" placeholder="<%= suggestedRedirectUri %>">
          </div>
          <%- include('../partials/voult-form-footer') %>
          <button type="submit" class="btn btn-outline-primary mt-2">signInWithEmailLink</button>
        </div>
      </form>
      <div class="alert alert-light border mt-4 small">
        <strong>Next:</strong> Click the link in email — it should hit
        <code>GET /voult/magic-callback?token=…</code>, which runs <code>verifyEmailLink</code> and saves the SDK session.
      </div>
      <p class="mt-3"><a href="/voult">← Playground</a></p>
    </div>
  </div>
</div>
