<% layout('layout/boilerplate.ejs') %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <h1 class="h3 mb-3">Sign in — email</h1>
      <form action="/signin/email" method="POST" class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="mb-3">
            <label class="form-label" for="email">Email</label>
            <input class="form-control" id="email" name="email" type="email" autocomplete="email" required>
          </div>
          <div class="mb-3">
            <label class="form-label" for="password">Password</label>
            <input class="form-control" id="password" name="password" type="password" autocomplete="current-password" required>
          </div>
          <%- include('../partials/voult-form-footer') %>
          <button type="submit" class="btn btn-dark mt-2">signInWithEmailAndPassword</button>
        </div>
      </form>
      <p class="mt-3"><a href="/voult">← Playground</a></p>
    </div>
  </div>
</div>
