<%- layout('layout/boilerplate.ejs') %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-10">
      <h1 class="h3 mb-3">Account Settings</h1>
      <p class="text-secondary mb-4">Manage your profile, sessions, linked OAuth providers, and account settings.</p>

      <% if (profile) { %>
        <div class="alert alert-success d-flex align-items-center gap-2" role="status">
          <i class="fa-solid fa-circle-check"></i>
          <span>Signed in as <strong><%= profile.email || profile.username || 'User' %></strong></span>
        </div>
      <% } %>

      <div class="row g-4 mt-1">
        <div class="col-lg-6">
          <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white fw-semibold">
              <i class="fa-solid fa-user-pen me-2"></i>Profile
            </div>
            <div class="card-body">
              <form action="/voult/settings/profile" method="POST" class="row g-3 align-items-end">
                <input type="hidden" name="_method" value="PATCH">
                <div class="col-12">
                  <label class="form-label" for="fullName">Full Name</label>
                  <input class="form-control" id="fullName" name="fullName" type="text" value="<%= profile && profile.fullName ? profile.fullName : '' %>" required>
                </div>
                <div class="col-12">
                  <button type="submit" class="btn btn-primary btn-sm">Update Profile</button>
                </div>
              </form>
            </div>
          </div>

          <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white fw-semibold">
              <i class="fa-solid fa-lock me-2"></i>Password
            </div>
            <div class="card-body">
              <form action="/voult/settings/set-password" method="POST" class="row g-3 align-items-end">
                <div class="col-12">
                  <label class="form-label" for="password">New Password</label>
                  <input class="form-control" id="password" name="password" type="password" required>
                </div>
                <div class="col-12">
                  <button type="submit" class="btn btn-warning btn-sm">Set Password</button>
                </div>
              </form>

              <hr class="my-4">

              <h6 class="fw-semibold">Reset Password via Email</h6>
              <form action="/voult/settings/forgot-password" method="POST" class="row g-3 align-items-end">
                <div class="col-12">
                  <label class="form-label" for="resetEmail">Email</label>
                  <input class="form-control" id="resetEmail" name="email" type="email" required>
                </div>
                <div class="col-12">
                  <button type="submit" class="btn btn-outline-secondary btn-sm">Send Reset Link</button>
                </div>
              </form>
            </div>
          </div>

          <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white fw-semibold">
              <i class="fa-solid fa-link me-2"></i>Linked OAuth Providers
            </div>
            <div class="card-body">
              <% if (linkedProviders && linkedProviders.length > 0) { %>
                <ul class="list-group list-group-flush mb-3">
                  <% linkedProviders.forEach(function(p) { %>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                      <span class="text-capitalize"><%= p.provider || p %></span>
                      <form action="/voult/settings/oauth/<%= p.provider || p %>/unlink?_method=DELETE" method="POST" class="d-inline">
                        <button type="submit" class="btn btn-outline-danger btn-sm">Unlink</button>
                      </form>
                    </li>
                  <% }) %>
                </ul>
              <% } else { %>
                <p class="text-muted small">No linked OAuth providers.</p>
              <% } %>

              <h6 class="fw-semibold mt-3">Link a new provider</h6>
              <div class="d-flex flex-wrap gap-2">
                <% providers.forEach(function(provider) { %>
                  <form action="/voult/settings/oauth/<%= provider %>/link" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-outline-primary btn-sm"><%= provider %></button>
                  </form>
                <% }) %>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white fw-semibold">
              <i class="fa-solid fa-desktop me-2"></i>Active Sessions
            </div>
            <div class="card-body">
              <% if (sessions && sessions.length > 0) { %>
                <ul class="list-group list-group-flush">
                  <% sessions.forEach(function(s) { %>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                      <div>
                        <strong><%= s.id %></strong>
                        <small class="text-muted d-block"><%= s.ipAddress || '' %> · <%= s.userAgent || '' %></small>
                        <small class="text-muted">Created: <%= s.createdAt %> · Last used: <%= s.lastUsedAt %></small>
                      </div>
                      <a href="/voult/settings/sessions/<%= s.id %>/revoke" class="btn btn-outline-danger btn-sm">Revoke</a>
                    </li>
                  <% }) %>
                </ul>
              <% } else { %>
                <p class="text-muted small">No active sessions.</p>
              <% } %>
            </div>
          </div>

          <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white fw-semibold">
              <i class="fa-solid fa-triangle-exclamation me-2"></i>Account Actions
            </div>
            <div class="card-body d-flex flex-wrap gap-2">
              <a href="/voult/account" class="btn btn-dark btn-sm">Back to Account</a>
              <form action="/voult/settings/reenable" method="POST" class="d-inline" onsubmit="return confirm('Re-enable this account?');">
                <button type="submit" class="btn btn-outline-success btn-sm">Re-enable Account</button>
              </form>
            </div>
          </div>
        </div>
      </div>

      <p class="mt-4 mb-0"><a href="/voult">← Playground</a></p>
    </div>
  </div>
</div>
