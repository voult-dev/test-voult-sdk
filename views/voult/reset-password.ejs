<% layout('layout/boilerplate.ejs') %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <h1 class="h3 mb-3">Reset Password</h1>
      <p class="text-secondary small mb-3">Reset your password using the token from the reset email link.</p>
      <form action="/voult/reset-password" method="POST" class="card shadow-sm border-0">
        <div class="card-body p-4">
          <div class="mb-3">
            <label class="form-label" for="token">Reset Token</label>
            <input class="form-control font-monospace small" id="token" name="token" type="text" required>
            <div class="form-text">Paste the token from the reset email URL.</div>
          </div>
          <div class="mb-3">
            <label class="form-label" for="appId">App ID</label>
            <input class="form-control font-monospace small" id="appId" name="appId" type="text" required>
            <div class="form-text">Use your Voult app ID.</div>
          </div>
          <div class="mb-3">
            <label class="form-label" for="password">New Password</label>
            <input class="form-control" id="password" name="password" type="password" required>
          </div>
          <input type="hidden" name="_redirect" value="1">
          <button type="submit" class="btn btn-primary">Reset Password</button>
        </div>
      </form>
      <p class="mt-3"><a href="/voult/signin/email">← Sign in</a></p>
    </div>
  </div>
</div>
